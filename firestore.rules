rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Phase 3: Primitive Definition (Helpers)
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "pixistaking@gmail.com" ||
        request.auth.token.email == "admin@pixi.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // Phase 4: Validation Blueprints (Strict Schemas)
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'balance', 'totalCommissionsEarned', 'referralCode', 'role', 'createdAt']) &&
             data.keys().size() == 7 &&
             data.uid is string && data.uid.size() > 0 &&
             data.email is string && data.email.size() < 100 &&
             data.balance is number && data.balance >= 0 &&
             data.totalCommissionsEarned is number && data.totalCommissionsEarned >= 0 &&
             data.referralCode is string && data.referralCode.size() >= 5 &&
             data.role in ['admin', 'user'] &&
             data.createdAt == request.time;
    }

    function isValidInvestment(data) {
      return data.keys().hasAll(['userId', 'userEmail', 'amount', 'planId', 'planName', 'startDate', 'endDate', 'lastPayoutDate', 'status']) &&
             data.keys().size() == 9 &&
             data.userId is string && data.userId.size() > 0 &&
             data.amount is number && data.amount > 0 &&
             data.planId is string &&
             data.status in ['pending', 'active', 'completed', 'rejected'] &&
             data.startDate == request.time;
    }

    function isValidDeposit(data) {
      return data.keys().hasAll(['userId', 'amount', 'screenshotUrl', 'status', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.userId is string &&
             data.amount is number && data.amount > 0 &&
             data.screenshotUrl is string && data.screenshotUrl.size() < 2048 &&
             data.status == 'pending' &&
             data.createdAt == request.time;
    }

    function isValidWithdrawal(data) {
      return data.keys().hasAll(['userId', 'amount', 'walletAddress', 'status', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.userId is string &&
             data.amount is number && data.amount > 0 &&
             data.walletAddress is string && data.walletAddress.size() >= 20 &&
             data.status == 'pending' &&
             data.createdAt == request.time;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['title', 'message', 'createdAt']) &&
             data.keys().size() == 3 &&
             data.title is string && data.title.size() < 200 &&
             data.message is string && data.message.size() < 5000 &&
             data.createdAt == request.time;
    }

    // ===============================================================
    // Phase 4: Path Specific Rules
    // ===============================================================

    match /users/{userId} {
      allow get: if (isValidId(userId) && isOwner(userId)) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isValidId(userId) && isOwner(userId) && 
                      isValidUser(incoming()) &&
                      incoming().balance == 0 &&
                      incoming().role == 'user';
                      
      allow update: if isValidId(userId) && (isSignedIn() && (
        isAdmin() || (
          isOwner(userId) &&
          incoming().uid == existing().uid &&
          incoming().role == existing().role &&
          incoming().createdAt == existing().createdAt &&
          (
            incoming().diff(existing()).affectedKeys().hasOnly(['email']) ||
            (incoming().diff(existing()).affectedKeys().hasAll(['balance', 'totalCommissionsEarned']) && 
             incoming().balance > existing().balance)
          )
        )
      ));
    }

    match /investments/{investmentId} {
      allow get: if isValidId(investmentId) && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isValidId(investmentId) && isSignedIn() && 
                      incoming().userId == request.auth.uid && 
                      isValidInvestment(incoming());
                      
      allow update: if isValidId(investmentId) && (isAdmin() || (
        isOwner(existing().userId) &&
        incoming().diff(existing()).affectedKeys().hasOnly(['lastPayoutDate', 'status']) &&
        existing().status == 'active'
      ));
    }

    match /deposits/{depositId} {
      allow get: if isValidId(depositId) && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isValidId(depositId) && isSignedIn() && 
                      incoming().userId == request.auth.uid && 
                      isValidDeposit(incoming());
                      
      allow update: if isValidId(depositId) && isAdmin() && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['status']);
    }

    match /withdrawals/{withdrawalId} {
      allow get: if isValidId(withdrawalId) && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isValidId(withdrawalId) && isSignedIn() && 
                      incoming().userId == request.auth.uid && 
                      isValidWithdrawal(incoming());
                      
      allow update: if isValidId(withdrawalId) && isAdmin() && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['status']);
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidNotification(incoming());
    }

    match /referrals/{referralId} {
      allow read: if resource.data.referrerUid == request.auth.uid || resource.data.referredUid == request.auth.uid || isAdmin();
      allow create: if isSignedIn() && incoming().referredUid == request.auth.uid;
      allow update: if (isAdmin() || (
        resource.data.referredUid == request.auth.uid &&
        incoming().diff(existing()).affectedKeys().hasOnly(['isActiveInvestor'])
      ));
    }
  }
}
